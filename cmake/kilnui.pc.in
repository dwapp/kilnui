prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/include/kilnui

Name: kilnui
Description: Lightweight UI rendering library built on Clay and SDL3 GPU
URL: https://github.com/rewine/kilnui
Version: @PROJECT_VERSION@
Requires: @PKG_CONFIG_REQUIRES@
Cflags: -I${includedir} -I${includedir}/clay
Libs: -L${libdir} -lkilnui
